{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.jmedure/talkback",
  "description": "Chat with your Ableton session in real-time.",
  "repository": {
    "url": "https://github.com/jmedure/talkback-mcp",
    "source": "github"
  },
  "version": "0.1.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "talkback-mcp",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "WebSocket port for the Max for Live bridge connection",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "WS_PORT"
        }
      ]
    }
  ]
}
